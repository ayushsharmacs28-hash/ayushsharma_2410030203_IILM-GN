# 🔴 🔹 ADVANCED QUERIES (36–40)

```sql
-- 36. Most ordered item
SELECT item_code, SUM(quantity) AS total_quantity
FROM Orders
GROUP BY item_code
ORDER BY total_quantity DESC
LIMIT 1;

-- 37. Customer with highest spending
SELECT c.Firstname, SUM(o.amount) AS total_spent
FROM Customer c
JOIN Order_details o ON c.customer_id = o.customer_id
GROUP BY c.customer_id
ORDER BY total_spent DESC
LIMIT 1;

-- 38. Orders with more than 1 item
SELECT order_id
FROM Orders
GROUP BY order_id
HAVING COUNT(item_code) > 1;

-- 39. Revenue per restaurant
SELECT r.Name, SUM(o.amount) AS revenue
FROM Restaurant r
JOIN Category c ON r.restaurant_id = c.restaurant_id
JOIN Menu_Item m ON c.Category_id = m.Category_id
JOIN Orders od ON m.item_code = od.item_code
JOIN Order_details o ON od.order_id = o.order_id
GROUP BY r.restaurant_id;

-- 40. Customers who ordered more than once
SELECT customer_id, COUNT(*) AS total_orders
FROM Order_details
GROUP BY customer_id
HAVING COUNT(*) > 1;
```




