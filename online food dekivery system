# 🔵 🔹 JOIN QUERIES (26–35)

```sql
-- 26. Customer name with order details
SELECT c.Firstname, o.order_id, o.amount
FROM Customer c
JOIN Order_details o ON c.customer_id = o.customer_id;

-- 27. Show items in each order
SELECT o.order_id, m.item_name, o.quantity
FROM Orders o
JOIN Menu_Item m ON o.item_code = m.item_code;

-- 28. Show customer + delivery status
SELECT c.Firstname, d.status
FROM Customer c
JOIN Order_details o ON c.customer_id = o.customer_id
JOIN Delivery_status d ON o.order_id = d.order_id;

-- 29. Show customer + payment mode
SELECT c.Firstname, p.mode
FROM Customer c
JOIN Order_details o ON c.customer_id = o.customer_id
JOIN Payment_details p ON o.order_id = p.order_id;

-- 30. Show restaurant + categories
SELECT r.Name, c.Name
FROM Restaurant r
JOIN Category c ON r.restaurant_id = c.restaurant_id;

-- 31. Show category + items
SELECT c.Name, m.item_name
FROM Category c
JOIN Menu_Item m ON c.Category_id = m.Category_id;

-- 32. Show full order details
SELECT c.Firstname, o.order_id, m.item_name, od.quantity
FROM Customer c
JOIN Order_details o ON c.customer_id = o.customer_id
JOIN Orders od ON o.order_id = od.order_id
JOIN Menu_Item m ON od.item_code = m.item_code;

-- 33. Show order + delivery + payment
SELECT o.order_id, d.status, p.mode
FROM Order_details o
JOIN Delivery_status d ON o.order_id = d.order_id
JOIN Payment_details p ON o.order_id = p.order_id;

-- 34. Show restaurant + menu items
SELECT r.Name, m.item_name
FROM Restaurant r
JOIN Category c ON r.restaurant_id = c.restaurant_id
JOIN Menu_Item m ON c.Category_id = m.Category_id;

-- 35. Show customer + restaurant ordered from
SELECT c.Firstname, r.Name
FROM Customer c
JOIN Order_details o ON c.customer_id = o.customer_id
JOIN Orders od ON o.order_id = od.order_id
JOIN Menu_Item m ON od.item_code = m.item_code
JOIN Category cat ON m.Category_id = cat.Category_id
JOIN Restaurant r ON cat.restaurant_id = r.restaurant_id;
```

